@Bad DSP-408 magic@dsp408 and dsp408.magic != 0x808080ee@[65535,40000,40000][0,0,0]
@Bad DSP-408 checksum@dsp408.checksum_ok == 0@[65535,40000,40000][0,0,0]
@DSP-408 abandoned multi-frame@_ws.expert.message contains "Abandoned"@[65535,55000,40000][0,0,0]
@DSP-408 WRITE (host→dev)@dsp408.direction == 0xa1@[55000,60000,65535][0,0,0]
@DSP-408 WRITE ack (dev→host)@dsp408.direction == 0x51@[50000,65535,55000][0,0,0]
@DSP-408 READ request@dsp408.direction == 0xa2@[60000,60000,65535][0,0,0]
@DSP-408 READ reply@dsp408.direction == 0x53@[55000,65535,65535][0,0,0]
@DSP-408 multi-frame continuation@dsp408.continuation_of@[65535,65535,55000][0,0,0]
@DSP-408 persist trigger (save→flash)@dsp408.cmd_name contains "preset_save_trigger" or dsp408.cmd_name contains "factory_reset"@[65535,45000,45000][0,0,0]
