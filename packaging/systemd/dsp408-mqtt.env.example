# /etc/default/dsp408-mqtt — environment for dsp408-mqtt.service
#
# Install:
#     sudo cp packaging/systemd/dsp408-mqtt.env.example /etc/default/dsp408-mqtt
#     sudoedit /etc/default/dsp408-mqtt
#
# After editing:
#     sudo systemctl restart dsp408-mqtt

# Absolute path to the `dsp408` entry point. If you installed via
# `uv sync`, it lives in the project venv:
#   DSP408_BIN=/home/pi/usb_dsp_mac/.venv/bin/dsp408
# If you installed via `pip install --user` or system pip, it's
# typically in /usr/local/bin or ~/.local/bin.
DSP408_BIN=/home/pi/usb_dsp_mac/.venv/bin/dsp408

# Arguments passed to `dsp408 mqtt`. Split on whitespace by systemd.
# Add --username / --password / --topic-prefix / --poll-interval as
# needed. --aliases is optional; if omitted, the bridge falls back to
# the XDG search order (/etc/dsp408/aliases.toml, then
# $XDG_CONFIG_HOME/dsp408/aliases.toml, then ./dsp408-aliases.toml).
DSP408_ARGS=--broker 10.21.0.138

# Examples:
#   DSP408_ARGS=--broker mqtt.local --username ha --password secret
#   DSP408_ARGS=--broker 192.168.1.5 --topic-prefix audio/dsp408 --poll-interval 1.5
#   DSP408_ARGS=--broker 10.21.0.138 --aliases /etc/dsp408/aliases.toml
